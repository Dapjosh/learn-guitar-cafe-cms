              "course_category": {
                "type": "Link",
                "config": {
                  "label": "Course Category",
                  "select": "document",
                  "repeat": false,
                  "customtypes": [
                    {
                      "id": "course_category",
                      "fields": [
                        "name"
                      ]
                    }
                  ]
                }
              },
              "course_image": {
                "type": "Image",
                "config": {
                  "label": "Course Image"
                }
              },
              "instructor": {
                "type": "Text",
                "config": {
                  "label": "Instructor"
                }
              },
              "course_title": {
                "type": "StructuredText",
                "config": {
                  "single": "paragraph",
                  "label": "Course Title"
                }
              },
              "duration": {
                "type": "Text",
                "config": {
                  "label": "Duration"
                }
              },
              "students_count": {
                "type": "Number",
                "config": {
                  "label": "Students Count"
                }
              },
              "original_price": {
                "type": "Text",
                "config": {
                  "label": "Original Price"
                }
              },
              "current_price": {
                "type": "Text",
                "config": {
                  "label": "Current Price"
                }
              },
              "cta_link": {
                "type": "Link",
                "config": {
                  "label": "Course CTA Link",
                  "allowText": true,
                  "repeat": false,
                  "select": null
                }
              }
            }
          }
        },
        "show_shadow": {
          "type": "Boolean",
          "config": {
            "label": "Show Card Shadow"
          }
        }
