          "config": {
            "single": "paragraph",
            "label": "Section Description"
          }
        },
        "all_courses_link": {
          "type": "Link",
          "config": {
            "label": "All Courses Link",
            "allowText": true,
            "repeat": false,
            "select": null
          }
        },
        "button_text": {
          "type": "Text",
          "config": {
            "label": "button_text",
            "placeholder": ""
          }
        },
        "courses": {
          "type": "Group",
          "config": {
            "label": "Courses",
